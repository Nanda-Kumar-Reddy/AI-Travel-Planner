# Frontend Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local

# Backend API URL
# Development: http://localhost:5000
# Production: https://ai-travel-planner-api.onrender.com
NEXT_PUBLIC_API_URL=<your-backend-url>

# Google OAuth Client ID — used by the GIS "Sign in with Google" button
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized JavaScript origins must include your frontend URL
# Leave empty to disable Google Sign-In entirely (button will not appear)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=<your-google-oauth-client-id>

