# Backend Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit the .env file.
#
# Startup validation (server.ts): the server checks ALL required vars below
# on boot and crashes immediately with a clear list of what's missing.
# This converts silent mid-request failures into loud, immediate deploy errors.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=<port>
NODE_ENV=<development|production>

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# REQUIRED — server will not start without this.
# From Atlas dashboard → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ai-travel-planner?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────────────────────
# REQUIRED — server will not start without this.
# Phase 11: renamed from JWT_SECRET to JWT_ACCESS_SECRET.
# Existing sessions signed with the old JWT_SECRET will be invalidated
# (one-time forced re-login for all users — expected, intentional).
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=<your-64-char-random-hex-string>

# ── Google Gemini ──────────────────────────────────────────────────────────────
# REQUIRED — server will not start without this.
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=<your-gemini-api-key>

# ── Frontend URL ───────────────────────────────────────────────────────────────
# REQUIRED — used for CORS allowlist AND email verification links.
# Server will not start without this.
# Set to http://localhost:3000 in development.
# Set to your Vercel deployment URL in production (comma-separated for multiple).
FRONTEND_URL=<http://localhost:3000 or your Vercel URL>

# ── Weather mock ───────────────────────────────────────────────────────────────
# Set to "true" on demo day if Open-Meteo is unreachable.
# When true, the risk service returns a deterministic mock weather flag.
WEATHER_MOCK=false

# ── Phase 11: Auth System Expansion ──────────────────────────────────────────

# Email mode — controls how verification emails are sent:
#   mock: log the verification link to the server console (safe for dev/demo)
#   live: send via Resend HTTP API (requires RESEND_KEY)
# Default when unset: mock (safe fallback — demo never breaks without email config)
EMAIL_MODE=mock

# Resend API key — required when EMAIL_MODE=live.
# Startup validation enforces this is present before the server starts.
# Get from: https://resend.com/api-keys (free plan: 100 emails/day, 3k/month)
RESEND_KEY=<your-resend-api-key>

# From address — optional override. Must be a domain you have verified in the
# Resend dashboard. Defaults to onboarding@resend.dev (Resend's shared testing
# domain — delivers to any inbox immediately, no DNS setup needed).
# EMAIL_FROM_ADDRESS=no-reply@yourdomain.com

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Client ID — used on both frontend GIS button and backend token verification.
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized JavaScript origins: http://localhost:3000, https://your-vercel-app.vercel.app
# Leave empty to disable Google Sign-In entirely (the button will not appear).
GOOGLE_CLIENT_ID=<your-google-oauth-client-id>
