# Backend Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit the .env file.

# Server
PORT=<port>
NODE_ENV=<development|production>

# MongoDB Atlas connection string (from Atlas dashboard → Connect → Drivers)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/ai-travel-planner?retryWrites=true&w=majority

# JWT secret for access tokens — generate with: openssl rand -hex 32
# Phase 11: renamed from JWT_SECRET to JWT_ACCESS_SECRET
JWT_ACCESS_SECRET=<your-64-char-random-hex-string>

# Google Gemini API key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=<your-gemini-api-key>

# Frontend URL (for CORS + email links — set to http://localhost:3000 in development)
FRONTEND_URL=<http://localhost:3000 or your Vercel URL>

# Weather mock — set to "true" on demo day if Open-Meteo is unreachable
# When true, the risk service returns a deterministic mock weather flag
# (disclosed in README known limitations)
WEATHER_MOCK=false

# ── Phase 11: Auth System Expansion ──────────────────────────────────────────

# Email mode — controls how verification emails are sent:
#   mock: log the verification link to the server console (safe for dev/demo)
#   live: send via Gmail SMTP / nodemailer (requires SMTP_USER + SMTP_PASS)
# Default when unset: mock (safe fallback — demo never breaks due to email credentials)
EMAIL_MODE=mock

# Gmail SMTP credentials — required only when EMAIL_MODE=live
# SMTP_USER: your Gmail address (e.g. yourname@gmail.com)
# SMTP_PASS: a Gmail App Password (NOT your Google account password)
#   Generate at: Google Account → Security → 2-Step Verification → App Passwords
#   Select "Mail" and "Other (Custom name)", generate, copy the 16-char password
SMTP_USER=<your-gmail-address>
SMTP_PASS=<your-gmail-app-password>

# From address display name (appears in email "From" header)
EMAIL_FROM=AI Travel Planner

# Email hard block — when true, unverified users cannot log in (403).
# When false/unset (default), unverified users see a non-blocking reminder banner.
# Recommended: keep false at launch to avoid permanent lockout from email delivery issues.
EMAIL_VERIFY_REQUIRED=false

# Google OAuth — Client ID (used on both frontend GIS button and backend token verification)
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized JavaScript origins: http://localhost:3000, https://your-vercel-app.vercel.app
# Leave empty to disable Google Sign-In entirely
GOOGLE_CLIENT_ID=<your-google-oauth-client-id>
